import mainHtml from "../legacy/contact-main.html?raw";

const scriptHtml = getPageScripts("contact");
---

<LegacyShell title='Contact | Mads LIU Yong' description='Personal academic website of Mads LIU Yong.' current='contact' mainClass='main' path="contact.html" scriptHtml={scriptHtml}>
