---
import LegacyShell from "../components/LegacyShell.astro";
import { getPageScripts } from "../data/site";
import mainHtml from "../legacy/research-log-main.html?raw";
import projectInfoHtml from "../legacy/research-graduation-project-info.html?raw";

const scriptHtml = getPageScripts("research-log");
---

<LegacyShell title='Research Log | Mads LIU YONG' description='Project-based research log of Mads LIU YONG.' current='research-log' mainClass='main research-log-main' path="research-log.html" scriptHtml={scriptHtml}>
  <Fragment set:html={mainHtml} />
  <Fragment set:html={projectInfoHtml} />
</LegacyShell>
