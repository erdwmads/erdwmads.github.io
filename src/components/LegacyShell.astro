---
interface Props {
  title: string;
  description: string;
  current: string;
  mainClass?: string;
  scriptHtml: string;
}

const { title, description, current, mainClass = "main", scriptHtml } = Astro.props;
const navItems = [
  { href: "index.html", label: "Home", key: "home" },
  { href: "research.html", label: "Research", key: "research" },
  { href: "research-log.html", label: "Research Log", key: "research-log" },
  { href: "paper-shelf.html", label: "Paper Shelf", key: "paper-shelf" },
  { href: "cv.html", label: "CV", key: "cv" },
  { href: "photography.html", label: "Photography", key: "photography" },
  { href: "contact.html", label: "Contact", key: "contact" }
];
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{title}</title>
  <meta name="description" content={description}>
  <script is:inline>
    (function () {
      try {
        var savedTheme = localStorage.getItem("mads-theme");
        if (savedTheme === "space") {
          document.documentElement.setAttribute("data-theme", "space");
          document.documentElement.setAttribute("data-theme-space", "");
          document.documentElement.classList.add("theme-preloaded-space");
          document.documentElement.style.backgroundColor = "#040910";
        } else {
          document.documentElement.setAttribute("data-theme", "light");
          document.documentElement.style.backgroundColor = "#edf3f7";
        }
      } catch (error) {
        document.documentElement.setAttribute("data-theme", "light");
        document.documentElement.style.backgroundColor = "#edf3f7";
      }
    })();
  </script>
  <style is:inline>
    html { background: #edf3f7; color-scheme: light dark; }
    html[data-theme="space"],
    html[data-theme-space] {
      background: #040910 !important;
      color-scheme: dark;
    }
    html[data-theme="space"] body,
    html[data-theme-space] body {
      background-color: #040910 !important;
      color: #edf7ff;
    }
  </style>
  <link rel="stylesheet" href="assets/css/style.css">
  <link rel="icon" href="favicon.ico" sizes="any">
  <link rel="icon" type="image/png" href="assets/img/favicon.png">
  <link rel="apple-touch-icon" href="assets/img/apple-touch-icon.png">
</head>
<body>
<header class="site-header">
  <div class="header-inner">
    <a class="brand" href="index.html">
      <strong>Mads LIU YONG</strong>
      <span>Cosmic Mineralogy | Planetary Sciences | Meteoritics</span>
    </a>
    <nav class="nav" aria-label="Main navigation">
      {navItems.map((item) => <a href={item.href} aria-current={current === item.key ? "page" : undefined}>{item.label}</a>)}
      <button class="theme-toggle" type="button" aria-label="Toggle light and space mode">Space Mode</button>
    </nav>
  </div>
</header>
<main class={mainClass}>
  <slot />
</main>
<footer class="site-footer">
  <div class="footer-inner">
    <span>(c) 2026 Mads LIU YONG</span>
    <span>Built for GitHub Pages</span>
  </div>
</footer>
<Fragment set:html={scriptHtml} />
<script src="assets/js/legacy-navigation.js" defer></script>
</body>
</html>
