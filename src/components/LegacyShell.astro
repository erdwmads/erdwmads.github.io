---
import { brand, footerItems, navItems, siteMetadata } from "../data/site";

interface Props {
  title: string;
  description: string;
  current: string;
  mainClass?: string;
  path?: string;
  scriptHtml: string;
  locked?: boolean;
}

const { title, description, current, mainClass = "main", path, scriptHtml, locked = false } = Astro.props;
const canonicalPath = path || "index.html";
const canonicalUrl = new URL(canonicalPath, `${siteMetadata.url}/`).toString();
const imageUrl = new URL(siteMetadata.image, `${siteMetadata.url}/`).toString();
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{title}</title>
  <meta name="description" content={description}>
  <link rel="canonical" href={canonicalUrl}>
  <meta name="theme-color" content="#040910" media="(prefers-color-scheme: dark)">
  <meta name="theme-color" content="#edf3f7" media="(prefers-color-scheme: light)">
  <meta property="og:type" content="website">
  <meta property="og:site_name" content={siteMetadata.title}>
  <meta property="og:locale" content={siteMetadata.locale}>
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:url" content={canonicalUrl}>
  <meta property="og:image" content={imageUrl}>
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>
  <meta name="twitter:image" content={imageUrl}>
  <script is:inline>
    (function () {
      try {
        var savedTheme = localStorage.getItem("mads-theme");
        if (savedTheme === "space") {
          document.documentElement.setAttribute("data-theme", "space");
          document.documentElement.setAttribute("data-theme-space", "");
          document.documentElement.classList.add("theme-preloaded-space");
          document.documentElement.style.backgroundColor = "#040910";
        } else {
          document.documentElement.setAttribute("data-theme", "light");
          document.documentElement.style.backgroundColor = "#edf3f7";
        }
      } catch (error) {
        document.documentElement.setAttribute("data-theme", "light");
        document.documentElement.style.backgroundColor = "#edf3f7";
      }
    })();
  </script>
  <style is:inline>
    html { background: #edf3f7; color-scheme: light dark; }
    html[data-theme="space"],
    html[data-theme-space] {
      background: #040910 !important;
      color-scheme: dark;
    }
    html[data-theme="space"] body,
    html[data-theme-space] body {
      background-color: #040910 !important;
      color: #edf7ff;
    }
  </style>
  <link rel="stylesheet" href="assets/css/style.css">
  <link rel="icon" href="favicon.ico" sizes="any">
  <link rel="icon" type="image/png" href="assets/img/favicon.png">
  <link rel="apple-touch-icon" href="assets/img/apple-touch-icon.png">
</head>
<body>
<header class="site-header">
  <div class="header-inner">
    <a class="brand" href={brand.homeHref}>
      <strong>{brand.name}</strong>
      <span set:html={brand.tagline} />
    </a>
    <nav class="nav" aria-label="Main navigation">
      {navItems.map((item) => <a href={item.href} aria-current={current === item.key ? "page" : undefined}>{item.label}</a>)}
      <button class="theme-toggle" type="button" aria-label="Toggle light and space mode">Space Mode</button>
    </nav>
  </div>
</header>
<main class={mainClass}>
  {locked && (
    <section class="research-lock-gate" data-research-lock-gate>
      <form class="research-lock-panel" data-research-lock-form>
        <p class="eyebrow">Access Required</p>
        <h1>Research Log Locked</h1>
        <p>Enter the research log password to open this page.</p>
        <label class="research-lock-field">
          <span>Password</span>
          <input type="password" name="password" autocomplete="current-password" required>
        </label>
        <button class="button" type="submit">Unlock</button>
        <p class="research-lock-message" data-research-lock-message aria-live="polite"></p>
      </form>
    </section>
  )}
  {locked ? (
    <div data-research-lock-content hidden>
      <slot />
    </div>
  ) : (
    <slot />
  )}
</main>
<footer class="site-footer">
  <div class="footer-inner">
    {footerItems.map((item) => <span>{item}</span>)}
  </div>
</footer>
<script is:inline src="assets/js/power-manager.js"></script>
<Fragment set:html={scriptHtml} />
<script src="assets/js/legacy-navigation.js" defer></script>
</body>
</html>

