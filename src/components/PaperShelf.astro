---
import { papers } from "../data/papers";

const filters = [
  { label: "All", query: "" },
  { label: "Dolomite", query: "dolomite carbonate carbonates" },
  { label: "CI / Orgueil", query: "ci chondrite orgueil ivuna" },
  { label: "Ryugu / Bennu", query: "ryugu bennu returned sample" },
  { label: "Methods", query: "xrd tem epma ir isotopes mineralogy" },
  { label: "Chronology", query: "chronology ages mn cr" }
];
---

<section>
  <p class="eyebrow">Paper Shelf</p>
  <h1>Paper Shelf</h1>
  <p class="lead">
    A curated reading shelf for papers related to my graduation research: dolomite, carbonates,
    CI chondrites, Orgueil, Ryugu, Bennu, aqueous alteration, and analytical mineralogy.
  </p>
</section>

<section class="section paper-shelf-tools" aria-label="Paper Shelf filters">
  <div class="paper-shelf-search">
    <label for="paper-search">Search</label>
    <input id="paper-search" type="search" placeholder="Search title, author, tag..." data-paper-search>
  </div>
  <div class="paper-filter-row" data-paper-filters>
    {filters.map((filter, index) => (
      <button
        class="paper-filter"
        type="button"
        data-paper-filter={filter.query}
        aria-pressed={index === 0 ? "true" : "false"}
      >
        {filter.label}
      </button>
    ))}
  </div>
</section>

<section class="section paper-shelf">
  {papers.map((paper) => (
    <article
      class="paper-card"
      data-paper-card
      data-paper-text={`${paper.status} ${paper.title} ${paper.authors} ${paper.summary} ${paper.tags.join(" ")}`.toLowerCase()}
    >
      <div class="paper-status">{paper.status}</div>
      <h2>{paper.title}</h2>
      <p class="muted">{paper.authors}</p>
      <p>{paper.summary}</p>
      <div class="project-tags">
        {paper.tags.map((tag) => <span>{tag}</span>)}
      </div>
    </article>
  ))}
</section>

<section class="section reading-constellation-section">
  <p class="eyebrow">Reading Constellation</p>
  <h2>How the references connect</h2>
  <div class="reading-constellation">
    <div class="reading-core">Dolomite Problem</div>
    <div>CI carbonates</div>
    <div>Orgueil / Ivuna</div>
    <div>Ryugu / Bennu</div>
    <div>Aqueous alteration</div>
    <div>Analytical mineralogy</div>
  </div>
</section>
